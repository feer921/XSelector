# Copy this file outside source control, for example to:
#   ./maven-secret.properties
# or pass its path with:
#   -PmavenCentralSecretFile=/absolute/path/to/maven-secret.properties
#
# Values may also be supplied through Gradle properties or environment variables.

# Central Portal User Token, not the old OSSRH password.
MAVEN_CENTRAL_USERNAME=token-username
MAVEN_CENTRAL_PASSWORD=token-password

# Preferred: ASCII-armored private key content from:
#   gpg --armor --export-secret-keys <KEY_ID>
# In CI, provide this as MAVEN_CENTRAL_SIGNING_KEY instead of storing it here.
MAVEN_CENTRAL_SIGNING_KEY=
MAVEN_CENTRAL_SIGNING_KEY_ID=
MAVEN_CENTRAL_SIGNING_PASSWORD=

# Alternative: point to an external ASCII-armored private key file.
# MAVEN_CENTRAL_SIGNING_KEY_FILE=/absolute/path/to/private-key.asc

# Legacy Gradle signing plugin keyring fallback.
# signing.keyId=
# signing.password=
# signing.secretKeyRingFile=/absolute/path/to/secring.gpg
